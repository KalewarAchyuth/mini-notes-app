<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>mini-notes-app</title>
</head>
<body>
    <h1>Edit</h1>

    <form method="POST" action="/update/<%= idx %>">
        <label >Note : </label>
        <input 
            type="text" 
            name="note"
            value="<%= note %>"
        >                                       
        <button>Edit</button>
    </form>
</body>
</html>